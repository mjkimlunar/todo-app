PORT=3000
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 초대 이메일 발송 (Resend: https://resend.com)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=onboarding@resend.dev
# 초대 이메일 속 참여 링크에 쓸 배포 주소 (없으면 요청 host로 자동 추정)
APP_URL=https://todo-app-7pd3.onrender.com

# cli.js / mcp-server.js가 조회할 모임의 숫자 id (Supabase SQL Editor에서
# `select id, invite_code from households;`로 확인). 웹 UI의 초대 코드가
# 아니라 households 테이블의 id 컬럼 값이다.
HOUSEHOLD_ID=1
